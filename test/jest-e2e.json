{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^generated/(.*)$": "<rootDir>/../generated/$1",
    "^prisma/(.*)$": "<rootDir>/../prisma/$1",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  }
}
